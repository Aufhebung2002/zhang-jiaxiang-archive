---
interface City {
  id: string;
  name: string;
  type: string;
  coordinates: [number, number];
  summary: string;
  districts: string[];
}

interface Province {
  province: string;
  visited: boolean;
  coordinates: [number, number];
  cities: City[];
}

export interface Props {
  journeys: Province[];
}

const { journeys = [] } = Astro.props;
---

<div class="jn-index" data-journey-index>
  {journeys.map((province, provinceIndex) => (
    <details
      class="jn-province"
      data-province={province.province}
      data-province-index={provinceIndex}
      open={provinceIndex === 0}
    >
      <summary class="jn-province-row" data-province-trigger={province.province}>
        <span class="jn-index-num">{String(provinceIndex + 1).padStart(2, "0")}</span>
        <span class="jn-index-name">{province.province}</span>
        <span class="jn-current-flag" data-current-province-label hidden>当前</span>
        <span class="jn-index-meta">{province.cities.length} 个城市</span>
        <span class="jn-visited-flag">{province.visited ? "已点亮" : "未点亮"}</span>
      </summary>
      <div class="jn-city-list">
        {province.cities.map((city, cityIndex) => (
          <details class="jn-city" data-city-id={city.id}>
            <summary
              class="jn-city-row"
              data-place-id={city.id}
              data-province-name={province.province}
            >
              <span class="jn-index-num">
                {String(provinceIndex + 1).padStart(2, "0")}.{String(cityIndex + 1).padStart(2, "0")}
              </span>
              <span class="jn-index-name">{city.name}</span>
              <span class:list={["jn-type", `jn-type-${city.type}`]}>{city.type}</span>
            </summary>
            <div class="jn-city-body">
              <div class="jn-field">
                <span class="jn-field-label">坐标</span>
                <span>{city.coordinates[0].toFixed(4)}, {city.coordinates[1].toFixed(4)}</span>
              </div>
              <div class="jn-field">
                <span class="jn-field-label">摘要</span>
                <span>{city.summary}</span>
              </div>
              <div class="jn-districts">
                <span class="jn-field-label">区县</span>
                {city.districts.length > 0 ? (
                  <ul>
                    {city.districts.map((district) => <li>{district}</li>)}
                  </ul>
                ) : (
                  <span class="jn-pending">区/县信息待补充</span>
                )}
              </div>
            </div>
          </details>
        ))}
      </div>
    </details>
  ))}
</div>
