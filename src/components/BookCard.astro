---
export interface Props {
  id: string;
  title: string;
  author: string;
  field: string;
  status: string;
  year?: string;
  language?: string;
  tags: string[];
  externalLinks?: { douban?: string; other?: string };
  sizeHint: "small" | "medium" | "large";
}

const { id, title, author, field, status, year, language, tags, externalLinks, sizeHint } = Astro.props;

const displayTags = (tags || [])
  .filter((t) => !/^\d{4}$/.test(t) && !["中文", "英文", "Chinese", "English", "Traditional Chinese"].includes(t))
  .slice(0, 3);
---

<div class="bk-card" data-size={sizeHint} data-id={id}>
  <span class="bk-card-field">{field}</span>
  <span class="bk-card-title">{title}</span>
  <span class="bk-card-author">{author}</span>

  <div class="bk-card-meta">
    {year && <span class="bk-card-meta-item">{year}</span>}
    {language && <span class="bk-card-meta-item">{language}</span>}
    <span class="bk-card-status">{status}</span>
  </div>

  {displayTags.length > 0 && (
    <div class="bk-card-tags">
      {displayTags.map((t) => <span class="bk-card-tag">{t}</span>)}
    </div>
  )}

  {externalLinks?.douban && (
    <div class="bk-card-douban">
      <a href={externalLinks.douban} target="_blank" rel="noopener">豆瓣</a>
    </div>
  )}
</div>
