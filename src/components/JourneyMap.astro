---
import "leaflet/dist/leaflet.css";

interface City {
  id: string;
  name: string;
  type: string;
  coordinates: [number, number];
  summary: string;
  districts: string[];
}

interface Province {
  province: string;
  visited: boolean;
  coordinates: [number, number];
  cities: City[];
}

export interface Props {
  journeys: Province[];
}

const { journeys = [] } = Astro.props;
const journeysJson = JSON.stringify(journeys);
const cityCount = journeys.reduce((sum, province) => sum + province.cities.length, 0);
---

<div class="journey-map-wrapper">
  <div class="journey-map-toolbar" aria-label="地图状态">
    <div class="journey-map-meta">
      <span data-province-layer-status>省界数据：尝试加载</span>
      <span>城市标记：{cityCount} 个</span>
    </div>
    <div class="journey-map-layer-legend" aria-label="省份点亮图例">
      <span class="journey-map-legend-item">
        <span class="journey-map-swatch journey-map-swatch-visited"></span>
        已点亮省份
      </span>
      <span class="journey-map-legend-item">
        <span class="journey-map-swatch journey-map-swatch-unvisited"></span>
        未点亮省份
      </span>
    </div>
  </div>
  <div id="journey-map"></div>
  <noscript>
    <div class="journey-map-fallback">
      <p>地图需要 JavaScript 支持。地点档案索引见下方列表。</p>
    </div>
  </noscript>
</div>

<script type="application/json" id="journey-map-data" set:html={journeysJson}></script>

<script>
  import L from "leaflet";

  const TYPE_CLASS = {
    "主线城市": "main",
    "旅行城市": "travel",
    "途经城市": "pending",
    "待补充": "pending",
  };

  const PROVINCE_ALIASES = {
    北京: "北京市",
    天津: "天津市",
    上海: "上海市",
    重庆: "重庆市",
    河北: "河北省",
    山西: "山西省",
    辽宁: "辽宁省",
    吉林: "吉林省",
    黑龙江: "黑龙江省",
    江苏: "江苏省",
    浙江: "浙江省",
    安徽: "安徽省",
    福建: "福建省",
    江西: "江西省",
    山东: "山东省",
    河南: "河南省",
    湖北: "湖北省",
    湖南: "湖南省",
    广东: "广东省",
    海南: "海南省",
    四川: "四川省",
    贵州: "贵州省",
    云南: "云南省",
    陕西: "陕西省",
    甘肃: "甘肃省",
    青海: "青海省",
    台湾: "台湾省",
    内蒙古: "内蒙古自治区",
    广西: "广西壮族自治区",
    西藏: "西藏自治区",
    宁夏: "宁夏回族自治区",
    新疆: "新疆维吾尔自治区",
    香港: "香港特别行政区",
    澳门: "澳门特别行政区",
  };

  const FALLBACK_PROVINCES = [
    { province: "北京市", coordinates: [39.9042, 116.4074] },
    { province: "天津市", coordinates: [39.3434, 117.3616] },
    { province: "河北省", coordinates: [38.0428, 114.5149] },
    { province: "山西省", coordinates: [37.8735, 112.5624] },
    { province: "内蒙古自治区", coordinates: [40.8175, 111.7656] },
    { province: "辽宁省", coordinates: [41.8057, 123.4315] },
    { province: "吉林省", coordinates: [43.8171, 125.3235] },
    { province: "黑龙江省", coordinates: [45.7422, 126.6617] },
    { province: "上海市", coordinates: [31.2304, 121.4737] },
    { province: "江苏省", coordinates: [32.0603, 118.7969] },
    { province: "浙江省", coordinates: [30.2674, 120.1528] },
    { province: "安徽省", coordinates: [31.8612, 117.2857] },
    { province: "福建省", coordinates: [26.0745, 119.2965] },
    { province: "江西省", coordinates: [28.682, 115.8582] },
    { province: "山东省", coordinates: [36.6683, 117.0208] },
    { province: "河南省", coordinates: [34.7657, 113.7536] },
    { province: "湖北省", coordinates: [30.5454, 114.3423] },
    { province: "湖南省", coordinates: [28.1127, 112.9838] },
    { province: "广东省", coordinates: [23.1291, 113.2644] },
    { province: "广西壮族自治区", coordinates: [22.8155, 108.3275] },
    { province: "海南省", coordinates: [20.0174, 110.3492] },
    { province: "重庆市", coordinates: [29.563, 106.5516] },
    { province: "四川省", coordinates: [30.5728, 104.0668] },
    { province: "贵州省", coordinates: [26.647, 106.6302] },
    { province: "云南省", coordinates: [25.0453, 102.7097] },
    { province: "西藏自治区", coordinates: [29.652, 91.1721] },
    { province: "陕西省", coordinates: [34.3416, 108.9398] },
    { province: "甘肃省", coordinates: [36.0611, 103.8343] },
    { province: "青海省", coordinates: [36.6209, 101.7802] },
    { province: "宁夏回族自治区", coordinates: [38.4872, 106.2309] },
    { province: "新疆维吾尔自治区", coordinates: [43.8256, 87.6168] },
    { province: "台湾省", coordinates: [23.6978, 120.9605] },
    { province: "香港特别行政区", coordinates: [22.3193, 114.1694] },
    { province: "澳门特别行政区", coordinates: [22.1987, 113.5439] },
  ];

  function flattenCities(journeys) {
    return journeys.flatMap(function (province) {
      return province.cities.map(function (city) {
        return {
          id: city.id,
          name: city.name,
          type: city.type || "待补充",
          coordinates: city.coordinates,
          summary: city.summary,
          province: province.province,
        };
      });
    });
  }

  function markerIcon(type, active) {
    const markerClass = TYPE_CLASS[type] || "pending";
    return L.divIcon({
      className: `journey-marker journey-marker-${markerClass}${active ? " is-active" : ""}`,
      html: "<span></span>",
      iconSize: [34, 34],
      iconAnchor: [17, 17],
      popupAnchor: [0, -18],
    });
  }

  function getProvinceName(properties) {
    if (!properties) return "";
    const raw =
      properties.name ||
      properties.NAME ||
      properties.fullname ||
      properties.fullName ||
      properties.province ||
      properties.Province ||
      properties.prov_name ||
      properties.adname ||
      properties.NAME_CHN ||
      properties["省"] ||
      properties["省份"] ||
      "";
    const name = String(raw).trim();
    return PROVINCE_ALIASES[name] || name;
  }

  function setProvinceLayerStatus(text) {
    const status = document.querySelector("[data-province-layer-status]");
    if (status) status.textContent = text;
  }

  function initMap() {
    const mapEl = document.getElementById("journey-map");
    const dataEl = document.getElementById("journey-map-data");
    if (!mapEl || !dataEl) return;

    let journeys = [];
    try {
      journeys = JSON.parse(dataEl.textContent || "[]");
    } catch (error) {
      console.warn("[JourneyMap] 旅程数据解析失败", error);
      return;
    }

    const cities = flattenCities(journeys);
    if (!cities.length) return;

    const visitedProvinces = new Map(
      journeys.map(function (province) {
        return [province.province, province];
      })
    );

    function getProvinceRecord(provinceName) {
      return visitedProvinces.get(provinceName);
    }

    function isProvinceVisited(provinceName) {
      return Boolean(getProvinceRecord(provinceName)?.visited);
    }

    function getFallbackProvinces() {
      const provinceMap = new Map(
        FALLBACK_PROVINCES.map(function (province) {
          return [province.province, province];
        })
      );

      journeys.forEach(function (province) {
        if (Array.isArray(province.coordinates)) {
          provinceMap.set(province.province, {
            province: province.province,
            coordinates: province.coordinates,
          });
        }
      });

      return Array.from(provinceMap.values());
    }

    const map = L.map("journey-map", {
      center: [34.6, 108.9],
      zoom: 5,
      scrollWheelZoom: true,
    });

    map.createPane("provincePane");
    map.getPane("provincePane").style.zIndex = "360";
    map.getPane("provincePane").style.pointerEvents = "auto";

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 18,
    }).addTo(map);

    let activeProvinceLayer = null;
    let resetActiveProvinceLayerStyle = null;
    let provinceLayer = null;
    const fallbackProvinceLayers = new Map();
    let hasWarnedMissingGeoJson = false;
    const markers = new Map();
    let activeId = "";
    let activeProvinceName = "";

    function provinceStyle(feature) {
      const provinceName = getProvinceName(feature.properties);
      const isVisited = isProvinceVisited(provinceName);
      const isActive = provinceName && provinceName === activeProvinceName;
      return {
        pane: "provincePane",
        color: isActive ? "#70421e" : isVisited ? "#8a5a2b" : "#c9bea9",
        weight: isActive ? (isVisited ? 2.2 : 1.45) : isVisited ? 1.1 : 0.65,
        opacity: isActive ? 0.9 : isVisited ? 0.72 : 0.5,
        fillColor: isVisited ? "#b78343" : "#eee8dc",
        fillOpacity: isActive ? (isVisited ? 0.5 : 0.28) : isVisited ? 0.34 : 0.18,
      };
    }

    function fallbackProvinceStyle(province, active) {
      const isVisited = isProvinceVisited(province.province);
      return {
        pane: "provincePane",
        radius: active ? (isVisited ? 28 : 22) : isVisited ? 24 : 19,
        color: isVisited ? "#8a5a2b" : "#c9bea9",
        weight: active ? 2 : 0.9,
        opacity: isVisited ? 0.72 : 0.5,
        fillColor: isVisited ? "#b78343" : "#eee8dc",
        fillOpacity: active ? (isVisited ? 0.46 : 0.28) : isVisited ? 0.28 : 0.16,
      };
    }

    function resetActiveProvinceLayer() {
      if (!activeProvinceLayer || !resetActiveProvinceLayerStyle) return;
      resetActiveProvinceLayerStyle(activeProvinceLayer);
      activeProvinceLayer = null;
      resetActiveProvinceLayerStyle = null;
    }

    function setActiveProvinceLayer(layer, applyActiveStyle, resetStyle) {
      if (activeProvinceLayer && resetActiveProvinceLayerStyle) {
        resetActiveProvinceLayerStyle(activeProvinceLayer);
      }

      activeProvinceLayer = layer;
      resetActiveProvinceLayerStyle = resetStyle;
      applyActiveStyle(layer);
      layer.bringToFront();
    }

    function setActiveProvince(provinceName, options = {}) {
      const expand = Boolean(options.expand);
      activeProvinceName = provinceName || "";

      document.querySelectorAll("[data-province]").forEach(function (details) {
        const isActive = details.getAttribute("data-province") === activeProvinceName;
        const row = details.querySelector("[data-province-trigger]");
        details.classList.toggle("is-active", isActive);
        if (row) {
          row.classList.toggle("is-active", isActive);
          if (isActive) {
            row.setAttribute("aria-current", "location");
          } else {
            row.removeAttribute("aria-current");
          }
        }

        const currentLabel = details.querySelector("[data-current-province-label]");
        if (currentLabel) currentLabel.hidden = !isActive;

        if (isActive && expand) {
          details.setAttribute("open", "");
        }
      });
    }

    function clearActiveCity() {
      activeId = "";
      document.querySelectorAll("[data-place-id]").forEach(function (row) {
        row.classList.remove("is-active");
      });

      markers.forEach(function (marker, id) {
        const markerCity = cities.find(function (item) {
          return item.id === id;
        });
        if (markerCity) marker.setIcon(markerIcon(markerCity.type, false));
      });

      map.closePopup();
    }

    function setActiveListItem(placeId, provinceName) {
      document.querySelectorAll("[data-place-id]").forEach(function (row) {
        row.classList.toggle("is-active", row.getAttribute("data-place-id") === placeId);
      });

      const cityDetails = document.querySelector(`[data-city-id="${placeId}"]`);
      if (cityDetails) cityDetails.setAttribute("open", "");

      setActiveProvince(provinceName, { expand: true });
      activateProvinceLayer(provinceName);
    }

    function highlightProvinceLayer(layer, feature) {
      const provinceName = getProvinceName(feature.properties);
      setActiveProvinceLayer(
        layer,
        function (activeLayer) {
          activeLayer.setStyle(provinceStyle(feature));
        },
        function (activeLayer) {
          if (provinceLayer) {
            provinceLayer.resetStyle(activeLayer);
          }
        }
      );
    }

    function highlightFallbackProvinceLayer(layer, province) {
      setActiveProvinceLayer(
        layer,
        function (activeLayer) {
          activeLayer.setStyle(fallbackProvinceStyle(province, true));
        },
        function (activeLayer) {
          activeLayer.setStyle(fallbackProvinceStyle(province, false));
        }
      );
    }

    function activateProvinceLayer(provinceName) {
      if (!provinceName) {
        resetActiveProvinceLayer();
        return null;
      }

      if (provinceLayer) {
        let matchedLayer = null;
        provinceLayer.eachLayer(function (layer) {
          const layerProvinceName = getProvinceName(layer.feature && layer.feature.properties);
          if (layerProvinceName === provinceName) {
            matchedLayer = layer;
          }
        });

        if (matchedLayer) {
          highlightProvinceLayer(matchedLayer, matchedLayer.feature);
          return matchedLayer;
        }
      }

      if (fallbackProvinceLayers.has(provinceName)) {
        const fallbackProvince = fallbackProvinceLayers.get(provinceName);
        highlightFallbackProvinceLayer(fallbackProvince.layer, fallbackProvince.province);
        return fallbackProvince.layer;
      }

      resetActiveProvinceLayer();
      return null;
    }

    function focusProvince(provinceName, options = {}) {
      const province = getProvinceRecord(provinceName);
      setActiveProvince(provinceName, { expand: Boolean(options.expand) });
      const layer = activateProvinceLayer(provinceName);

      if (layer && typeof layer.getBounds === "function") {
        map.fitBounds(layer.getBounds().pad(0.08), { maxZoom: 6 });
        return;
      }

      if (province && Array.isArray(province.coordinates)) {
        map.flyTo(province.coordinates, 6, { duration: 0.65 });
      }
    }

    function addFallbackProvinceLayer() {
      const fallbackLayer = L.layerGroup([], { pane: "provincePane" }).addTo(map);
      getFallbackProvinces().forEach(function (province) {
        const isVisited = isProvinceVisited(province.province);
        const layer = L.circleMarker(province.coordinates, fallbackProvinceStyle(province, false))
          .bindTooltip(`${province.province}｜${isVisited ? "已点亮" : "未点亮"}`, {
            direction: "top",
            sticky: true,
            className: "journey-province-tooltip",
          })
          .addTo(fallbackLayer);

        layer.on({
          mouseover: function () {
            layer.setStyle(fallbackProvinceStyle(province, true));
          },
          mouseout: function () {
            if (layer !== activeProvinceLayer) {
              layer.setStyle(fallbackProvinceStyle(province, false));
            }
          },
          click: function () {
            if (!isVisited) return;
            clearActiveCity();
            focusProvince(province.province, { expand: true });
          },
        });

        fallbackProvinceLayers.set(province.province, { layer, province });
      });

      setProvinceLayerStatus("省界数据：概略层");
    }

    function addProvinceLayer() {
      fetch("/data/china-provinces.geojson")
        .then(function (response) {
          if (!response.ok) {
            throw new Error(`HTTP ${response.status}`);
          }
          return response.json();
        })
        .then(function (geojson) {
          provinceLayer = L.geoJSON(geojson, {
            pane: "provincePane",
            style: provinceStyle,
            onEachFeature: function (feature, layer) {
              const provinceName = getProvinceName(feature.properties);
              const isVisited = isProvinceVisited(provinceName);

              layer.bindTooltip(provinceName || "未命名省份", {
                direction: "top",
                sticky: true,
                className: "journey-province-tooltip",
              });

              layer.on({
                mouseover: function () {
                  layer.setStyle({
                    weight: isVisited ? 1.8 : 1.1,
                    fillOpacity: isVisited ? 0.44 : 0.24,
                  });
                },
                mouseout: function () {
                  if (layer !== activeProvinceLayer && provinceLayer) {
                    provinceLayer.resetStyle(layer);
                  }
                },
                click: function () {
                  if (!isVisited) return;
                  clearActiveCity();
                  focusProvince(provinceName, { expand: true });
                },
              });
            },
          }).addTo(map);

          if (activeProvinceName) {
            activateProvinceLayer(activeProvinceName);
          }

          setProvinceLayerStatus("省界数据：精确省界");
        })
        .catch(function (error) {
          addFallbackProvinceLayer();
          if (!hasWarnedMissingGeoJson) {
            console.warn(
              "[JourneyMap] 未加载省级 GeoJSON。请提供 public/data/china-provinces.geojson；地图将使用概略省份色块。",
              error
            );
            hasWarnedMissingGeoJson = true;
          }
        });
    }

    function activateCity(placeId, source) {
      const city = cities.find(function (item) {
        return item.id === placeId;
      });
      if (!city) return;

      activeId = city.id;
      markers.forEach(function (marker, id) {
        const markerCity = cities.find(function (item) {
          return item.id === id;
        });
        if (markerCity) marker.setIcon(markerIcon(markerCity.type, id === activeId));
      });

      const zoom = city.type === "待补充" || city.type === "途经城市" ? 9 : 10;
      map.flyTo(city.coordinates, zoom, { duration: 0.65 });
      setActiveListItem(city.id, city.province);

      if (source !== "marker") {
        const marker = markers.get(city.id);
        if (marker) marker.openPopup();
      }

      window.dispatchEvent(
        new CustomEvent("journey:city-active", {
          detail: { id: city.id, province: city.province },
        })
      );
    }

    addProvinceLayer();

    cities.forEach(function (city) {
      const marker = L.marker(city.coordinates, {
        icon: markerIcon(city.type, false),
        title: `${city.province} / ${city.name}`,
      }).addTo(map);

      marker.bindPopup(
        `<div class="journey-popup">
          <strong>${city.name}</strong>
          <span>${city.type}</span>
          <p>${city.province}</p>
          <p>${city.summary}</p>
        </div>`
      );

      marker.on("click", function () {
        activateCity(city.id, "marker");
      });
      markers.set(city.id, marker);
    });

    const group = L.featureGroup(Array.from(markers.values()));
    map.fitBounds(group.getBounds().pad(0.12));

    document.addEventListener("click", function (event) {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const cityRow = target.closest("[data-place-id]");
      if (cityRow) {
        event.preventDefault();
        activateCity(cityRow.getAttribute("data-place-id"), "list");
        return;
      }

      const provinceRow = target.closest("[data-province-trigger]");
      if (provinceRow) {
        const provinceName = provinceRow.getAttribute("data-province-trigger");
        const province = getProvinceRecord(provinceName);
        if (!province) return;
        clearActiveCity();
        focusProvince(provinceName);
      }
    });

    setTimeout(function () {
      map.invalidateSize();
    }, 100);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initMap);
  } else {
    initMap();
  }
</script>
