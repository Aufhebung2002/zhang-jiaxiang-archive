---
import "leaflet/dist/leaflet.css";

interface Journey {
  id: string;
  title: string;
  lat: number;
  lng: number;
  type: string;
  date: string;
  summary: string;
}

export interface Props {
  journeys: Journey[];
}

const { journeys = [] } = Astro.props;
const journeysJson = JSON.stringify(journeys);
---

<div class="journey-map-wrapper">
  <div id="journey-map" style="height: 420px; width: 100%;"></div>
  <noscript>
    <div class="journey-map-fallback">
      <p>地图需要 JavaScript 支持。地点列表如下方所示。</p>
    </div>
  </noscript>
</div>

<script type="application/json" id="journey-map-data" set:html={journeysJson}></script>

<script>
  import L from "leaflet";

  function initMap() {
    var mapEl = document.getElementById("journey-map");
    if (!mapEl) {
      console.warn("[JourneyMap] container not found");
      return;
    }

    var dataEl = document.getElementById("journey-map-data");
    var journeys = [];

    try {
      var raw = dataEl ? dataEl.textContent || "" : "";
      journeys = JSON.parse(raw || "[]");
    } catch (error) {
      console.warn("[JourneyMap] JSON 数据解析失败", error);
      journeys = [];
      return;
    }

    if (!journeys || journeys.length === 0) {
      console.warn("[JourneyMap] 旅程数据为空");
      return;
    }

    try {
      // 创建自定义图标
      var markerIcon = L.icon({
        iconUrl: "https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png",
        iconRetinaUrl: "https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png",
        shadowUrl: "https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png",
        iconSize: [25, 41],
        iconAnchor: [12, 41],
        popupAnchor: [1, -34],
        shadowSize: [41, 41],
      });

      var map = L.map("journey-map", {
        center: [32.6, 117.6],
        zoom: 6,
        scrollWheelZoom: true,
      });

      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        attribution:
          '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        maxZoom: 18,
      }).addTo(map);

      var markers = [];
      journeys.forEach(function (j) {
        var marker = L.marker([j.lat, j.lng], { icon: markerIcon }).addTo(map);
        marker.bindPopup(
          '<div style="font-family: system-ui, sans-serif; max-width: 220px;">' +
            '<strong style="font-size: 0.95rem;">' + j.title + "</strong>" +
            '<span style="display: inline-block; margin-left: 0.4rem; font-size: 0.7rem; color: #8b6f47; border: 1px solid #c4a97d; padding: 0.05rem 0.4rem; border-radius: 3px;">' +
            j.type +
            "</span>" +
            '<div style="font-size: 0.75rem; color: #9c9285; margin-top: 0.3rem;">' +
            j.date +
            "</div>" +
            '<div style="font-size: 0.82rem; color: #6b6156; margin-top: 0.35rem; line-height: 1.5;">' +
            j.summary +
            "</div>" +
            "</div>"
        );
        markers.push(marker);
      });

      if (markers.length > 1) {
        var group = L.featureGroup(markers);
        map.fitBounds(group.getBounds().pad(0.15));
      }

      setTimeout(function () {
        map.invalidateSize();
      }, 100);
    } catch (e) {
      console.warn("[JourneyMap] 地图初始化出错", e);
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initMap);
  } else {
    initMap();
  }
</script>

<style is:global>
  .journey-map-wrapper {
    border: 1px solid var(--color-border, #e8e4dc);
    border-radius: var(--radius, 5px);
    overflow: hidden;
    margin-bottom: 1.8rem;
  }
  .journey-map-fallback {
    text-align: center;
    padding: 3rem 1.2rem;
    color: var(--color-text-muted, #9c9285);
    font-size: 0.9rem;
  }
</style>
