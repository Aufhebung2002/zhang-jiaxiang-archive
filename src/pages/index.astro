---
import BaseLayout from "../layouts/BaseLayout.astro";
import profile from "../data/profile.json";
import journeys from "../data/journeys.json";
import books from "../data/books.json";
import links from "../data/links.json";

const stats = {
  journeys: journeys.length,
  books: books.length,
  links: links.length,
  notes: 1,
};

const archiveEntries = [
  {
    href: "/about",
    code: "01",
    serial: "ZJX-A01",
    type: "PERSONAL DOSSIER",
    title: "关于我",
    desc: "个人介绍、建站缘起与公开边界",
    status: "已归档",
    count: "1 份卷宗",
  },
  {
    href: "/journeys",
    code: "02",
    serial: "ZJX-G02",
    type: "GEO ARCHIVE",
    title: "旅程地图",
    desc: "成长、生活、求学、工作与旅行节点",
    status: "持续补录",
    count: `${stats.journeys} 个地点`,
  },
  {
    href: "/books",
    code: "03",
    serial: "ZJX-B03",
    type: "BOOK CATALOG",
    title: "我的书架",
    desc: "阅读、待读、分类和书目索引",
    status: "重点整理",
    count: `${stats.books} 本记录`,
  },
  {
    href: "/links",
    code: "04",
    serial: "ZJX-W04",
    type: "WEB REFERENCES",
    title: "网站收藏",
    desc: "思想资源、工具平台与学习入口",
    status: "开放索引",
    count: `${stats.links} 个链接`,
  },
  {
    href: "/notes",
    code: "05",
    serial: "ZJX-N05",
    type: "FIELD NOTES",
    title: "随笔",
    desc: "读书笔记、生活观察和阶段性思考",
    status: "缓慢写作",
    count: `${stats.notes} 篇文章`,
  },
];

const collectionFields = [
  { label: "建档编号", value: "ZJX-ARCHIVE-001" },
  { label: "建档人", value: profile.name },
  { label: "建档时间", value: profile.startedAt },
  { label: "馆藏范围", value: "阅读 / 地图 / 工具 / 随笔 / 个人履历" },
  { label: "整理状态", value: "长期维护，持续补录" },
  { label: "公开边界", value: "选择性公开的私人知识目录" },
];
---

<BaseLayout>
  <section class="hero archive-cover" aria-labelledby="archive-title">
    <div class="archive-cover-topline">
      <span>ARCHIVE INDEX</span>
      <span>GENERAL CATALOG</span>
      <span>DOSSIER NO. 001</span>
    </div>
    <div class="archive-cover-body">
      <div class="archive-cover-main">
        <p class="hero-overline">PRIVATE KNOWLEDGE ARCHIVE</p>
        <h1 id="archive-title">{profile.siteTitle}</h1>
        <p class="hero-text">一份关于阅读、旅程、工具、法学学习和个人思考的长期私人档案。</p>
      </div>
      <dl class="archive-cover-fields" aria-label="档案封面信息">
        {collectionFields.map((field) => (
          <div>
            <dt>{field.label}</dt>
            <dd>{field.value}</dd>
          </div>
        ))}
      </dl>
    </div>
    <div class="archive-cover-summary">
      <span>摘要</span>
      <p>它不是即时动态，也不是形象包装，而是把记忆、经验和知识逐步整理成可回望、可检索、可长期维护的目录。</p>
    </div>
  </section>

  <section class="archive-stats" aria-label="馆藏统计">
    <div class="stats-caption">
      <span>COLLECTION LEDGER</span>
      <span>馆藏数量摘要</span>
    </div>
    <div class="stats-grid">
      <div class="stat-item">
        <span class="stat-num">{String(stats.journeys).padStart(2, "0")}</span>
        <span class="stat-label">地点</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">{String(stats.books).padStart(2, "0")}</span>
        <span class="stat-label">书目</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">{String(stats.links).padStart(2, "0")}</span>
        <span class="stat-label">链接</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">{String(stats.notes).padStart(2, "0")}</span>
        <span class="stat-label">札记</span>
      </div>
    </div>
  </section>

  <section class="home-index">
    <div class="index-header">
      <span class="index-label">GENERAL CATALOG / 总目录索引</span>
      <span class="index-line"></span>
      <span class="index-status">OPEN SHELF</span>
    </div>
    <nav class="entry-cards archive-directory" aria-label="档案馆总目录">
      {archiveEntries.map((entry) => (
        <a href={entry.href} class="entry-card">
          <span class="entry-num">{entry.code}</span>
          <span class="entry-serial">{entry.serial}</span>
          <span class="entry-type">{entry.type}</span>
          <span class="entry-main">
            <strong class="entry-title">{entry.title}</strong>
            <span class="entry-desc">{entry.desc}</span>
          </span>
          <span class="entry-status">{entry.status}</span>
          <span class="entry-count">{entry.count}</span>
          <span class="entry-arrow" aria-hidden="true">ENTER</span>
        </a>
      ))}
    </nav>
  </section>
</BaseLayout>
