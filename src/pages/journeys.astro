---
import BaseLayout from "../layouts/BaseLayout.astro";
import JourneyMap from "../components/JourneyMap.astro";
import JourneyCard from "../components/JourneyCard.astro";
import journeys from "../data/journeys.json";

const totalProvinces = journeys.length;
const totalCities = journeys.reduce((sum, province) => sum + province.cities.length, 0);
const visitedProvinceNames = journeys.map((province) => province.province).join(" / ");
---

<BaseLayout>
  <section class="jn-header">
    <p class="jn-overline">JOURNEY ARCHIVE NO. 003</p>
    <h1 class="jn-page-title">旅程地图</h1>
    <p class="jn-page-intro">
      以省、市、区县为索引，记录成长、生活、求学、工作与旅行经过的空间档案。
    </p>
  </section>

  <section class="jn-dossier-summary" aria-label="旅程地图统计">
    <div class="jn-stat">
      <span class="jn-stat-label">已记录省级</span>
      <strong>{String(totalProvinces).padStart(2, "0")}</strong>
    </div>
    <div class="jn-stat">
      <span class="jn-stat-label">已记录城市</span>
      <strong>{String(totalCities).padStart(2, "0")}</strong>
    </div>
    <div class="jn-stat jn-stat-wide">
      <span class="jn-stat-label">已去过省份</span>
      <span>{visitedProvinceNames}</span>
    </div>
  </section>

  <JourneyMap journeys={journeys} />

  <section>
    <div class="section-label">
      <span class="section-label-text">GEOGRAPHIC INDEX</span>
      <span class="section-label-line"></span>
    </div>
    <JourneyCard journeys={journeys} />
  </section>

  <section class="jn-legend">
    <div class="section-label">
      <span class="section-label-text">LEGEND</span>
      <span class="section-label-line"></span>
    </div>
    <div class="jn-legend-grid">
      <div class="jn-legend-item">
        <span class="jn-legend-marker jn-legend-marker-main"></span>
        <span class="jn-legend-label">主线城市</span>
        <span class="jn-legend-desc">长期生活、学习、工作相关地点</span>
      </div>
      <div class="jn-legend-item">
        <span class="jn-legend-marker jn-legend-marker-travel"></span>
        <span class="jn-legend-label">旅行城市</span>
        <span class="jn-legend-desc">阶段性旅行和体验世界的节点</span>
      </div>
      <div class="jn-legend-item">
        <span class="jn-legend-marker jn-legend-marker-pending"></span>
        <span class="jn-legend-label">途经 / 待补充</span>
        <span class="jn-legend-desc">只保留档案占位，等待后续补充</span>
      </div>
    </div>
    <p class="jn-legend-note">
      当前仓库未发现中国省级边界 GeoJSON，省份 visited / unvisited 暂以统计条、图例和目录状态表达。
    </p>
  </section>
</BaseLayout>
